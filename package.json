{
  "name": "@openagp/sdk",
  "version": "0.0.2",
  "description": "Reference TypeScript SDK for the Agent Governance Protocol (AGP) — vendor-neutral standard for AI agent governance.",
  "license": "Apache-2.0",
  "homepage": "https://openagp.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/openagp/sdk-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/openagp/sdk-typescript/issues",
    "email": "hello@openagp.io"
  },
  "author": {
    "name": "OpenAGP contributors",
    "email": "hello@openagp.io",
    "url": "https://openagp.io"
  },
  "keywords": [
    "agp",
    "agent-governance",
    "openagp",
    "protocol",
    "ed25519",
    "rfc8785",
    "jcs",
    "ai-agents",
    "compliance",
    "governance"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@noble/curves": "^1.6.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "canonicalize": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ]
}
