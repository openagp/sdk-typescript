{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openagp.io/schemas/v0.1/discovery.json",
  "title": "AGP discovery document (.well-known/agp)",
  "description": "Capability and key discovery document published by every AGP-compliant actor at /.well-known/agp.",
  "type": "object",
  "properties": {
    "agp_version": { "$ref": "common.json#/$defs/agp_version" },
    "actor_kind": { "$ref": "common.json#/$defs/actor_kind" },
    "actor_id": {
      "type": "string",
      "description": "FQDN or registry-issued ID for this actor."
    },

    "conformance_levels": {
      "type": "array",
      "items": { "$ref": "common.json#/$defs/conformance_level" },
      "minItems": 1,
      "description": "Levels this actor implements. L1 is implied by listing L2 or L3."
    },

    "public_keys": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "key_id": { "$ref": "common.json#/$defs/key_id" },
          "purpose": {
            "type": "string",
            "enum": ["event_signing", "policy_signing", "decision_signing"]
          },
          "alg": { "type": "string", "const": "Ed25519" },
          "value": {
            "type": "string",
            "pattern": "^[A-Za-z0-9+/]+=*$",
            "minLength": 44,
            "maxLength": 44,
            "description": "Base64-encoded Ed25519 public key (32 raw bytes -> 44 base64 chars with padding)."
          },
          "valid_from": { "$ref": "common.json#/$defs/iso8601_utc" },
          "valid_until": { "$ref": "common.json#/$defs/iso8601_utc" }
        },
        "required": ["key_id", "purpose", "alg", "value"]
      }
    },

    "endpoints": {
      "type": "object",
      "description": "URLs for AGP endpoints this actor exposes. Field set varies by actor_kind.",
      "properties": {
        "events_receive": { "type": "string", "format": "uri" },
        "policy_receive": { "type": "string", "format": "uri" },
        "policy_read": { "type": "string", "format": "uri" },
        "decision_receive": { "type": "string", "format": "uri" }
      }
    },

    "decision_budget_ms": {
      "type": "integer",
      "minimum": 50,
      "maximum": 10000,
      "description": "Vendor's declared maximum wait for an L3 decision response. Default 300."
    },

    "supported_action_types": {
      "type": "array",
      "items": { "$ref": "common.json#/$defs/action_type" }
    },

    "registry_record": {
      "type": "string",
      "description": "Path or URL to this actor's registry entry. Optional; advisory only — the registry remains authoritative."
    }
  },

  "required": [
    "agp_version",
    "actor_kind",
    "actor_id",
    "conformance_levels",
    "public_keys"
  ]
}
